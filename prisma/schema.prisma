generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  password  String
  role      String   @default("user")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DataUser {
  id                 Int                    @id @default(autoincrement())
  name               String
  email              String
  phone              String?
  paketId            Int?
  isEmailSent        Boolean                @default(false)
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  listeningHistories UserListeningHistory[]
  readingHistories   UserReadingHistory[]
  speakingHistories  UserSpeakingHistory[]
  writingHistories   UserWritingHistory[]
  paket              Paket?                 @relation(fields: [paketId], references: [id])

  @@index([paketId], map: "DataUser_paketId_fkey")
}

model ReadingCategory {
  id          Int       @id @default(autoincrement())
  name        String
  description String?
  timer       Int
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  pakets      Paket[]   @relation("PaketToReadingCategory")
  readings    Reading[] @relation("ReadingToReadingCategory")
}

model Reading {
  id               Int                  @id @default(autoincrement())
  title            String
  content          String               @db.LongText
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  SoalReading      SoalReading[]
  readingHistories UserReadingHistory[]
  pakets           Paket[]              @relation("PaketToReading")
  categories       ReadingCategory[]    @relation("ReadingToReadingCategory")
}

model SoalReading {
  id        Int             @id @default(autoincrement())
  readingId Int
  question  String          @db.LongText
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  options   ReadingOption[]
  reading   Reading         @relation(fields: [readingId], references: [id], onDelete: Cascade)

  @@index([readingId], map: "SoalReading_readingId_fkey")
}

model ReadingOption {
  id            Int                        @id @default(autoincrement())
  soalReadingId Int
  text          String                     @db.Text
  imageUrl      String?
  isCorrect     Boolean                    @default(false)
  soalReading   SoalReading                @relation(fields: [soalReadingId], references: [id], onDelete: Cascade)
  userHistories UserReadingOptionHistory[]

  @@index([soalReadingId], map: "ReadingOption_soalReadingId_fkey")
}

model ListeningCategory {
  id          Int         @id @default(autoincrement())
  name        String
  description String?
  timer       Int
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  pakets      Paket[]     @relation("ListeningCategoryToPaket")
  listenings  Listening[] @relation("ListeningToListeningCategory")
}

model Listening {
  id                 Int                    @id @default(autoincrement())
  title              String
  content            String                 @db.LongText
  audioUrl           String?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt
  SoalListeing       SoalListeing[]
  listeningHistories UserListeningHistory[]
  categories         ListeningCategory[]    @relation("ListeningToListeningCategory")
  pakets             Paket[]                @relation("ListeningToPaket")
}

model SoalListeing {
  id         Int               @id @default(autoincrement())
  listeingId Int
  question   String            @db.LongText
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  options    ListeningOption[]
  listeing   Listening         @relation(fields: [listeingId], references: [id], onDelete: Cascade)

  @@index([listeingId], map: "SoalListeing_listeingId_fkey")
}

model ListeningOption {
  id              Int                          @id @default(autoincrement())
  soalListeingId  Int
  text            String                       @db.Text
  imageUrl        String?
  isCorrect       Boolean                      @default(false)
  soalListeing    SoalListeing                 @relation(fields: [soalListeingId], references: [id], onDelete: Cascade)
  optionHistories UserListeningOptionHistory[]

  @@index([soalListeingId], map: "ListeningOption_soalListeingId_fkey")
}

model WritingCategory {
  id          Int       @id @default(autoincrement())
  name        String
  description String?
  timer       Int
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  pakets      Paket[]   @relation("PaketToWritingCategory")
  writings    Writing[] @relation("WritingToWritingCategory")
}

model Writing {
  id               Int                  @id @default(autoincrement())
  title            String
  content          String
  jenis         JenisWriting @default(ESSAY)
  targetWords      Int @default(150)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  SoalWriting      SoalWriting[]
  writingHistories UserWritingHistory[]
  pakets           Paket[]              @relation("PaketToWriting")
  categories       WritingCategory[]    @relation("WritingToWritingCategory")
}

model SoalWriting {
  id            Int             @id @default(autoincrement())
  writingId     Int
  jenis         JenisWriting
  question      String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  AnswerWriting              AnswerWriting[]
  writing                    Writing                  @relation(fields: [writingId], references: [id], onDelete: Cascade)
  userSoalWritingHistories UserSoalWritingHistory[]

  @@index([writingId], map: "SoalWriting_writingId_fkey")
}

model AnswerWriting {
  id            Int         @id @default(autoincrement())
  soalWritingId Int
  answer        String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  soalWriting   SoalWriting @relation(fields: [soalWritingId], references: [id], onDelete: Cascade)

  @@index([soalWritingId], map: "AnswerWriting_soalWritingId_fkey")
}

model SpeakingCategory {
  id          Int        @id @default(autoincrement())
  name        String
  description String?
  timer       Int
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  pakets      Paket[]    @relation("PaketToSpeakingCategory")
  speakings   Speaking[] @relation("SpeakingToSpeakingCategory")
}

model Speaking {
  id                Int                   @id @default(autoincrement())
  title             String
  content           String
  jenis             JenisSpeaking
  audioUrl          String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  SoalSpeaking      SoalSpeaking[]
  speakingHistories UserSpeakingHistory[]
  pakets            Paket[]               @relation("PaketToSpeaking")
  categories        SpeakingCategory[]    @relation("SpeakingToSpeakingCategory")
}

model SoalSpeaking {
  id             Int              @id @default(autoincrement())
  speakingId     Int
  jenis          JenisSpeaking
  question       String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  AnswerSpeaking AnswerSpeaking[]
  speaking       Speaking         @relation(fields: [speakingId], references: [id], onDelete: Cascade)

  @@index([speakingId], map: "SoalSpeaking_speakingId_fkey")
}

model AnswerSpeaking {
  id             Int          @id @default(autoincrement())
  soalSpeakingId Int
  answer         String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  soalSpeaking   SoalSpeaking @relation(fields: [soalSpeakingId], references: [id], onDelete: Cascade)

  @@index([soalSpeakingId], map: "AnswerSpeaking_soalSpeakingId_fkey")
}

model Paket {
  id                  Int                 @id @default(autoincrement())
  name                String
  description         String?
  createdAt           DateTime            @updatedAt
  listeningCategories ListeningCategory[] @relation("ListeningCategoryToPaket")
  listenings          Listening[]         @relation("ListeningToPaket")
  readings            Reading[]           @relation("PaketToReading")
  readingCategories   ReadingCategory[]   @relation("PaketToReadingCategory")
  speakings           Speaking[]          @relation("PaketToSpeaking")
  speakingCategories  SpeakingCategory[]  @relation("PaketToSpeakingCategory")
  writings            Writing[]           @relation("PaketToWriting")
  writingCategories   WritingCategory[]   @relation("PaketToWritingCategory")
  dataUsers           DataUser[]
}

model UserReadingHistory {
  id              Int                        @id @default(autoincrement())
  userDataId      Int
  readingId       Int
  score           Int
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt
  reading         Reading                    @relation(fields: [readingId], references: [id], onDelete: Cascade)
  dataUser        DataUser                   @relation(fields: [userDataId], references: [id], onDelete: Cascade)
  optionHistories UserReadingOptionHistory[]
  soalHistories   UserSoalReadingHistory[]

  @@index([readingId], map: "UserReadingHistory_readingId_fkey")
  @@index([userDataId], map: "UserReadingHistory_userDataId_fkey")
}

model UserSoalReadingHistory {
  id                   Int                @id @default(autoincrement())
  userReadingHistoryId Int
  answer               String
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  userReadingHistory   UserReadingHistory @relation(fields: [userReadingHistoryId], references: [id], onDelete: Cascade)

  @@index([userReadingHistoryId], map: "UserSoalReadingHistory_userReadingHistoryId_fkey")
}

model UserReadingOptionHistory {
  id                   Int                @id @default(autoincrement())
  userReadingHistoryId Int
  readingOptionId      Int
  answer               String
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  readingOption        ReadingOption      @relation(fields: [readingOptionId], references: [id], onDelete: Cascade)
  userReadingHistory   UserReadingHistory @relation(fields: [userReadingHistoryId], references: [id], onDelete: Cascade)

  @@index([readingOptionId], map: "UserReadingOptionHistory_readingOptionId_fkey")
  @@index([userReadingHistoryId], map: "UserReadingOptionHistory_userReadingHistoryId_fkey")
}

model UserListeningHistory {
  id              Int                          @id @default(autoincrement())
  userDataId      Int
  listeningId     Int
  score           Int
  createdAt       DateTime                     @default(now())
  updatedAt       DateTime                     @updatedAt
  listening       Listening                    @relation(fields: [listeningId], references: [id], onDelete: Cascade)
  dataUser        DataUser                     @relation(fields: [userDataId], references: [id], onDelete: Cascade)
  optionHistories UserListeningOptionHistory[]
  soalHistories   UserSoalListeningHistory[]

  @@index([listeningId], map: "UserListeningHistory_listeningId_fkey")
  @@index([userDataId], map: "UserListeningHistory_userDataId_fkey")
}

model UserSoalListeningHistory {
  id                     Int                  @id @default(autoincrement())
  userListeningHistoryId Int
  answer                 String
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  userListeningHistory   UserListeningHistory @relation(fields: [userListeningHistoryId], references: [id], onDelete: Cascade)

  @@index([userListeningHistoryId], map: "UserSoalListeningHistory_userListeningHistoryId_fkey")
}

model UserListeningOptionHistory {
  id                     Int                  @id @default(autoincrement())
  userListeningHistoryId Int
  listeningOptionId      Int
  answer                 String
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  listeningOption        ListeningOption      @relation(fields: [listeningOptionId], references: [id], onDelete: Cascade)
  userListeningHistory   UserListeningHistory @relation(fields: [userListeningHistoryId], references: [id], onDelete: Cascade)

  @@index([listeningOptionId], map: "UserListeningOptionHistory_listeningOptionId_fkey")
  @@index([userListeningHistoryId], map: "UserListeningOptionHistory_userListeningHistoryId_fkey")
}

model UserWritingHistory {
  id            Int                      @id @default(autoincrement())
  userDataId    Int
  writingId     Int
  answer        String                   @db.Text
  score         Int
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt
  dataUser      DataUser                 @relation(fields: [userDataId], references: [id], onDelete: Cascade)
  writing       Writing                  @relation(fields: [writingId], references: [id], onDelete: Cascade)
  soalHistories UserSoalWritingHistory[]

  @@index([userDataId], map: "UserWritingHistory_userDataId_fkey")
  @@index([writingId], map: "UserWritingHistory_writingId_fkey")
}

model UserSoalWritingHistory {
  id                   Int                @id @default(autoincrement())
  userWritingHistoryId Int
  soalWritingId        Int
  answer               String             @db.Text
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  userWritingHistory   UserWritingHistory @relation(fields: [userWritingHistoryId], references: [id], onDelete: Cascade)
  soalWriting          SoalWriting        @relation(fields: [soalWritingId], references: [id], onDelete: Cascade)

  @@index([userWritingHistoryId], map: "UserSoalWritingHistory_userWritingHistoryId_fkey")
  @@index([soalWritingId], map: "UserSoalWritingHistory_soalWritingId_fkey")
}

model UserSpeakingHistory {
  id         Int      @id @default(autoincrement())
  userDataId Int
  speakingId Int
  answer     String
  score      Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  speaking   Speaking @relation(fields: [speakingId], references: [id], onDelete: Cascade)
  dataUser   DataUser @relation(fields: [userDataId], references: [id], onDelete: Cascade)

  @@index([speakingId], map: "UserSpeakingHistory_speakingId_fkey")
  @@index([userDataId], map: "UserSpeakingHistory_userDataId_fkey")
}

enum JenisSpeaking {
  MENIRU
  MENJAWAB
}

enum JenisWriting {
  ESSAY
  SHORT_ANSWER
}
